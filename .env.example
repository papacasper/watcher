# Alpaca Markets (free tier: 15-min delayed, IEX feed)
# Get keys at: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret

# Robinhood Credentials (username/password for robin_stocks-patterned auth)
RH_USERNAME=your_robinhood_username
RH_PASSWORD=your_robinhood_password
# MFA code if 2FA is enabled
# RH_MFA_CODE=123456

# Alert Thresholds
DXY_THRESHOLD=97.0
# Per-symbol price alert thresholds (comma-separated SYMBOL:price pairs)
# If unset, prices are displayed but no alerts fire.
# WATCH_THRESHOLDS=O:60.0,JEPI:52.0

# Symbols to watch (comma-separated); prices fetched from Alpaca.
# If unset, symbols are auto-detected from your Robinhood holdings.
# WATCH_SYMBOLS=O,JEPI

# Income Calculation
DAILY_COST=150
# One-off audit CLI: set true to run mock data instead of live Robinhood.
AUDIT_DEMO=false

# Polling Interval (ms)
POLL_INTERVAL_MS=60000

# Server refresh interval (ms); default 48h
REFRESH_MS=172800000

# Server bind settings. Default HOST is 127.0.0.1 for safety.
# Use a Tailscale IP or 0.0.0.0 only with DASHBOARD_PASSWORD set.
HOST=127.0.0.1
PORT=4242

# Optional dashboard Basic auth. Required for non-loopback HOST unless
# ALLOW_UNAUTH_REMOTE=true is explicitly set.
DASHBOARD_USER=watcher
# DASHBOARD_PASSWORD=change_me
# ALLOW_UNAUTH_REMOTE=false
