# All values are optional. First-run setup can be completed in the browser.

# Dashboard server
HOST=127.0.0.1
PORT=4242
REFRESH_MS=172800000
REFRESH_TIMEOUT_MS=90000
DASHBOARD_USER=watcher
DASHBOARD_PASSWORD=
ALLOW_UNAUTH_REMOTE=false

# Optional defaults used before browser setup
DIVIDEND_TARGET_DAILY=280
DAILY_COST=150

# Optional legacy Robinhood env fallback. Prefer browser setup.
RH_USERNAME=
RH_PASSWORD=
RH_MFA_CODE=

# Webhook called on portfolio events (goal_progress, guardrail_triggered, goal_and_guardrail)
# Payload: { event, goalProgressPct, goalMilestone?, newGuardrails?, fetchedAt }
WEBHOOK_URL=

# Optional cache locations
# WATCHER_CACHE_DIR=/home/you/.watcher
# RH_TOKEN_DIR=/home/you/.tokens

# Remote sync (used by bin/sync-remote.sh — copy to .env.local, never commit)
# WATCHER_REMOTE=user@your-server
# WATCHER_REMOTE_DIR=/home/user/dev/watcher
