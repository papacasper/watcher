{
  "name": "watcher",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build frontend/index.tsx --outfile=dist/bundle.js --minify",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit --skipLibCheck",
    "verify": "bun run build && bun run typecheck && bun test",
    "sync:remote": "bin/sync-remote.sh",
    "audit:deps": "bun audit",
    "watch": "bun bin/watch.ts",
    "audit": "bun bin/audit.ts",
    "dashboard": "bun bin/dashboard.ts",
    "server": "bun --env-file=.env bin/server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "elysia": "^1.4.28",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
